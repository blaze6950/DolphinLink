@using FlipperZero.Web.Playground
@using System.Text.Json

@* ResponseDisplay — formats a list of FieldDescriptors + their JSON values into a readable table. *@

@if (Fields is null || Fields.Count == 0)
{
    <span class="text-muted fst-italic">No response fields.</span>
    return;
}

@if (JsonResponse is null)
{
    return;
}

<table class="table table-sm table-bordered mb-0">
    <thead class="table-light">
        <tr>
            <th class="w-25">Field</th>
            <th>Value</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var field in Fields)
        {
            <tr>
                <td class="fw-semibold align-middle text-nowrap">
                    @field.Name
                    <span class="d-block text-muted small fw-normal font-monospace">@field.WireKey</span>
                </td>
                <td class="align-middle font-monospace">
                    @RenderValue(field)
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<FieldDescriptor>? Fields { get; set; }

    /// <summary>The parsed JSON response object from the daemon.</summary>
    [Parameter] public JsonElement? JsonResponse { get; set; }

    private string RenderValue(FieldDescriptor field)
    {
        if (JsonResponse is null) return "";

        if (!JsonResponse.Value.TryGetProperty(field.WireKey, out var el))
            return "(not present)";

        // Render depending on schema type
        return field.Type switch
        {
            "bool"     => el.ValueKind == JsonValueKind.Number
                            ? (el.GetInt32() != 0 ? "true" : "false")
                            : el.GetRawText(),
            "bytes"    => TryBase64(el),
            "hex"      => el.GetString() ?? el.GetRawText(),
            "uint[]"   => el.ValueKind == JsonValueKind.Array
                            ? string.Join(", ", el.EnumerateArray().Select(e => e.GetRawText()))
                            : el.GetRawText(),
            "string[]" => el.ValueKind == JsonValueKind.Array
                            ? string.Join(", ", el.EnumerateArray().Select(e => e.GetString() ?? e.GetRawText()))
                            : el.GetRawText(),
            "object"   or "object[]" => el.GetRawText(),
            _          => field.Enum is not null
                            ? LookupEnum(field, el)
                            : el.GetRawText()
        };
    }

    private static string TryBase64(JsonElement el)
    {
        var s = el.GetString();
        if (s is null) return el.GetRawText();
        try
        {
            var bytes = Convert.FromBase64String(s);
            return $"({bytes.Length} bytes) {s[..Math.Min(40, s.Length)]}{(s.Length > 40 ? "…" : "")}";
        }
        catch { return s; }
    }

    private static string LookupEnum(FieldDescriptor field, JsonElement el)
    {
        if (field.Enum is null) return el.GetRawText();

        var wireVal = el.ValueKind == JsonValueKind.Number
            ? el.GetInt32().ToString()
            : el.GetString() ?? el.GetRawText();

        var match = field.Enum.Values.FirstOrDefault(v => v.WireValue == wireVal);
        return match is not null ? $"{match.Name} ({wireVal})" : wireVal;
    }
}
