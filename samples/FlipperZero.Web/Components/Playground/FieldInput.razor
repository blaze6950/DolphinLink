@using FlipperZero.Web.Playground

@* FieldInput — renders the appropriate input widget for any FieldDescriptor. *@
@* The value is maintained in the parent's dictionary keyed by FieldDescriptor.Name. *@

@if (Field is null) { return; }

<div class="mb-2">
    <label class="form-label mb-1">
        <span class="fw-semibold">@Field.Name</span>
        @if (Field.Optional)
        {
            <span class="text-muted ms-1 small">(optional)</span>
        }
        <span class="text-muted ms-2 small font-monospace">@Field.Type@(Field.Enum is not null ? $" / {Field.Enum.Name}" : "")</span>
    </label>

    @if (Field.Enum is not null)
    {
        @* Enum → dropdown *@
        <select class="form-select form-select-sm" value="@GetString()" @onchange="OnSelectChanged">
            @if (Field.Optional)
            {
                <option value="">(not set)</option>
            }
            @foreach (var v in Field.Enum.Values)
            {
                <option value="@v.WireValue">@v.Name (@v.WireValue)</option>
            }
        </select>
    }
    else if (Field.Type == "bool")
    {
        @* bool → toggle *@
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox"
                   checked="@GetBool()"
                   @onchange="OnBoolChanged" />
        </div>
    }
    else if (Field.Type is "int" or "uint" or "byte" or "ushort")
    {
        @* numeric → number input *@
        <input class="form-control form-control-sm font-monospace"
               type="number"
               min="@MinFor(Field.Type)"
               max="@MaxFor(Field.Type)"
               placeholder="@(Field.Optional ? "leave blank to omit" : "required")"
               value="@GetString()"
               @onchange="OnTextChanged" />
    }
    else if (Field.Type == "hex")
    {
        @* hex bytes → text with hex hint *@
        <input class="form-control form-control-sm font-monospace"
               type="text"
               placeholder="e.g. DEADBEEF"
               value="@GetString()"
               @onchange="OnTextChanged" />
        <div class="form-text">Hex-encoded bytes (no spaces or 0x prefix).</div>
    }
    else if (Field.Type == "bytes")
    {
        @* base64 bytes → textarea + optional file picker *@
        <textarea class="form-control form-control-sm font-monospace"
                  rows="3"
                  placeholder="Base64-encoded bytes"
                  value="@GetString()"
                  @onchange="OnTextChanged"></textarea>
        <InputFile class="form-control form-control-sm mt-1" accept="*/*"
                   OnChange="OnFilePickedAsync" />
        <div class="form-text">Paste base64 or pick a file to encode it.</div>
    }
    else if (Field.Type is "uint[]")
    {
        @* uint array → comma-separated *@
        <input class="form-control form-control-sm font-monospace"
               type="text"
               placeholder="comma-separated integers, e.g. 100,200,300"
               value="@GetString()"
               @onchange="OnTextChanged" />
        <div class="form-text">Comma-separated unsigned integers.</div>
    }
    else if (Field.Type is "string[]")
    {
        @* string array → comma-separated *@
        <input class="form-control form-control-sm"
               type="text"
               placeholder="comma-separated strings"
               value="@GetString()"
               @onchange="OnTextChanged" />
        <div class="form-text">Comma-separated strings.</div>
    }
    else
    {
        @* string, or any unknown type → plain text *@
        <input class="form-control form-control-sm"
               type="text"
               placeholder="@(Field.Optional ? "leave blank to omit" : "required")"
               value="@GetString()"
               @onchange="OnTextChanged" />
    }

    @if (!string.IsNullOrEmpty(Field.Description) && Field.Description != Field.Name)
    {
        <div class="form-text">@Field.Description</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public FieldDescriptor Field { get; set; } = null!;

    /// <summary>
    /// Shared dictionary (keyed by field name) holding the raw string values for
    /// all fields in the parent form. The parent passes <c>@bind-Values</c>.
    /// </summary>
    [Parameter, EditorRequired] public Dictionary<string, string> Values { get; set; } = null!;
    [Parameter] public EventCallback<Dictionary<string, string>> ValuesChanged { get; set; }

    // ── Read helpers ───────────────────────────────────────────────────────

    private string GetString() => Values.TryGetValue(Field.Name, out var v) ? v : "";
    private bool GetBool() => Values.TryGetValue(Field.Name, out var v) && v is "true" or "1";

    // ── Write helpers ───────────────────────────────────────────────────────

    private async Task SetValue(string value)
    {
        Values[Field.Name] = value;
        await ValuesChanged.InvokeAsync(Values);
    }

    private async Task OnTextChanged(ChangeEventArgs e)
        => await SetValue(e.Value?.ToString() ?? "");

    private async Task OnBoolChanged(ChangeEventArgs e)
        => await SetValue(e.Value is true ? "true" : "false");

    private async Task OnSelectChanged(ChangeEventArgs e)
        => await SetValue(e.Value?.ToString() ?? "");

    private async Task OnFilePickedAsync(InputFileChangeEventArgs e)
    {
        try
        {
            // Read up to 1 MB
            const long maxSize = 1024 * 1024;
            await using var stream = e.File.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            await SetValue(Convert.ToBase64String(ms.ToArray()));
        }
        catch (Exception ex)
        {
            await SetValue($"ERROR: {ex.Message}");
        }
    }

    // ── Type range helpers ──────────────────────────────────────────────────

    private static string MinFor(string type) => type switch
    {
        "int"    => int.MinValue.ToString(),
        "uint"   => "0",
        "byte"   => "0",
        "ushort" => "0",
        _        => ""
    };

    private static string MaxFor(string type) => type switch
    {
        "int"    => int.MaxValue.ToString(),
        "uint"   => uint.MaxValue.ToString(),
        "byte"   => "255",
        "ushort" => ushort.MaxValue.ToString(),
        _        => ""
    };
}
