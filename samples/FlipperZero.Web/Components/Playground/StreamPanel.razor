@using FlipperZero.Web.Playground
@using FlipperZero.Web.Services
@using FlipperZero.NET
@using System.Text
@using System.Text.Json

@implements IAsyncDisposable

@inject FlipperClientService Flipper

@* StreamPanel — renders a start/stop form and live event log for a StreamDescriptor. *@

<div class="playground-item @(_collapsed ? "" : "playground-item--open") mb-2">

    @* ── Header (always visible) ────────────────────────────────────────────── *@
    <div class="playground-item-header"
         @onclick="ToggleCollapsed"
         title="@(_collapsed ? "Expand" : "Collapse")"
         role="button"
         tabindex="0"
         @onkeydown="OnKeyDown">

        <div class="playground-item-left">
            <span class="playground-method-badge playground-method-badge--stream">STREAM</span>
            <span class="playground-item-name">@Stream.DisplayName</span>
            <span class="badge bg-secondary font-monospace">#@Stream.CommandId</span>
            @if (_streaming)
            {
                <span class="badge bg-success">Live</span>
            }
            @if (Stream.Resource is not null)
            {
                <span class="badge playground-resource-badge" title="Acquires resource">@Stream.Resource</span>
            }
        </div>

        <div class="playground-item-right">
            <span class="playground-item-desc text-muted small">@Stream.Description</span>
            <span class="playground-item-arrow" aria-hidden="true">@(_collapsed ? "▶" : "▼")</span>
        </div>
    </div>

    @* ── Body (expanded only) ───────────────────────────────────────────────── *@
    @if (!_collapsed)
    {
        <div class="playground-item-body">

            @* ── Metadata row ─────────────────────────────────────────────── *@
            <div class="playground-meta mb-3">
                <span class="font-monospace small text-muted">
                    <span class="text-secondary">name:</span> @Stream.Name
                </span>
            </div>

            @* ── Start parameters ─────────────────────────────────────────── *@
            @if (Stream.RequestFields.Count > 0)
            {
                <div class="playground-section-label">Start parameters</div>
                <div class="playground-fields mb-3">
                    @foreach (var field in Stream.RequestFields)
                    {
                        <FieldInput Field="field"
                                    Values="_fieldValues"
                                    ValuesChanged="OnValuesChanged" />
                    }
                </div>
            }

            @* ── Start / Stop buttons ─────────────────────────────────────── *@
            <div class="d-flex align-items-center gap-2 mb-3">
                @if (!_streaming)
                {
                    <button class="btn btn-success btn-sm px-3"
                            @onclick="StartAsync"
                            disabled="@(_busy || !Flipper.IsConnected)">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Start Stream
                    </button>
                }
                else
                {
                    <button class="btn btn-danger btn-sm px-3"
                            @onclick="StopAsync"
                            disabled="@_busy">
                        Stop Stream
                    </button>
                }
                @if (!Flipper.IsConnected)
                {
                    <span class="text-muted small">Not connected</span>
                }
                @if (_eventCount > 0)
                {
                    <span class="badge bg-light text-dark border">@_eventCount event(s)</span>
                }
            </div>

            @* ── Error ────────────────────────────────────────────────────── *@
            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <strong>Error:</strong> @_errorMessage
                </div>
            }

            @* ── Event field schema ───────────────────────────────────────── *@
            @if (Stream.EventFields.Count > 0)
            {
                <div class="playground-section-label">Event fields</div>
                <table class="table table-sm table-bordered mb-3" style="font-size:0.82em">
                    <thead class="table-light">
                        <tr>
                            <th>Field</th>
                            <th>Wire key</th>
                            <th>Type</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ef in Stream.EventFields)
                        {
                            <tr>
                                <td class="fw-semibold">@ef.Name</td>
                                <td class="font-monospace text-muted">@ef.WireKey</td>
                                <td class="font-monospace text-muted">
                                    @ef.Type@(ef.Enum is not null ? $" / {ef.Enum.Name}" : "")
                                </td>
                                <td class="text-muted">@ef.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @* ── Event log ────────────────────────────────────────────────── *@
            @if (_events.Count > 0)
            {
                <div class="d-flex align-items-center justify-content-between mb-1">
                    <div class="playground-section-label mb-0">Event log</div>
                    <button class="btn btn-outline-secondary btn-sm py-0 px-2"
                            @onclick="ClearEvents">Clear</button>
                </div>

                <div class="border rounded overflow-auto font-monospace small"
                     style="max-height:300px; background:#1e1e1e; color:#d4d4d4;">
                    @foreach (var (idx, fields) in _events)
                    {
                        <div class="px-2 py-1 border-bottom border-secondary"
                             style="border-color:#444 !important">
                            <span class="text-secondary me-2">#@idx</span>
                            @if (Stream.EventFields.Count > 0)
                            {
                                @foreach (var ef in Stream.EventFields)
                                {
                                    <span class="me-3">
                                        <span style="color:#9cdcfe">@ef.WireKey</span>
                                        <span style="color:#808080">=</span>
                                        <span style="color:#ce9178">@RenderEventField(ef, fields)</span>
                                    </span>
                                }
                            }
                            else
                            {
                                @foreach (var kv in fields)
                                {
                                    <span class="me-3">
                                        <span style="color:#9cdcfe">@kv.Key</span>
                                        <span style="color:#808080">=</span>
                                        <span style="color:#ce9178">@kv.Value.GetRawText()</span>
                                    </span>
                                }
                            }
                        </div>
                    }
                </div>
            }

        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public StreamDescriptor Stream { get; set; } = null!;

    private Dictionary<string, string> _fieldValues = new();
    private bool   _busy;
    private bool   _collapsed  = true;
    private bool   _streaming;
    private string? _errorMessage;
    private int    _eventCount;

    private readonly List<(int idx, Dictionary<string, JsonElement> fields)> _events = new();
    private const int MaxEvents = 200;

    private RpcStream<GenericStreamEvent>? _activeStream;
    private CancellationTokenSource? _stopCts;

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ") ToggleCollapsed();
    }

    private Task OnValuesChanged(Dictionary<string, string> values)
    {
        _fieldValues = values;
        return Task.CompletedTask;
    }

    private void ClearEvents()
    {
        _events.Clear();
        _eventCount = 0;
    }

    private async Task StartAsync()
    {
        if (Flipper.Client is null) return;

        _busy = true;
        _errorMessage = null;
        ClearEvents();

        try
        {
            var argsJson = BuildRequestJson();
            using var argsDoc = JsonDocument.Parse(argsJson);
            var argsElement   = argsDoc.RootElement.Clone();

            var cmd = new GenericStreamStartCommand(Stream.CommandId, Stream.Name, argsElement);
            _activeStream = await Flipper.Client
                .SendStreamAsync<GenericStreamStartCommand, GenericStreamEvent>(cmd)
                .ConfigureAwait(false);

            _streaming = true;
            _stopCts   = new CancellationTokenSource();
            _ = RunEventLoopAsync(_activeStream, _stopCts.Token);
        }
        catch (FlipperRpcException ex)
        {
            _errorMessage = $"{ex.ErrorCode}: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RunEventLoopAsync(RpcStream<GenericStreamEvent> stream, CancellationToken ct)
    {
        try
        {
            await foreach (var evt in stream.WithCancellation(ct).ConfigureAwait(false))
            {
                var fields = evt.Fields ?? new Dictionary<string, JsonElement>();
                var idx    = ++_eventCount;

                await InvokeAsync(() =>
                {
                    if (_events.Count >= MaxEvents) _events.RemoveAt(0);
                    _events.Add((idx, fields));
                    StateHasChanged();
                }).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
            // User stopped the stream — not an error.
        }
        catch (Exception ex)
        {
            await InvokeAsync(() =>
            {
                _errorMessage = ex.Message;
                StateHasChanged();
            }).ConfigureAwait(false);
        }
        finally
        {
            await InvokeAsync(() =>
            {
                _streaming = false;
                StateHasChanged();
            }).ConfigureAwait(false);
        }
    }

    private async Task StopAsync()
    {
        _busy = true;
        try
        {
            _stopCts?.Cancel();
            if (_activeStream is not null)
            {
                await _activeStream.DisposeAsync().ConfigureAwait(false);
                _activeStream = null;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _streaming = false;
            _busy      = false;
            _stopCts?.Dispose();
            _stopCts   = null;
        }
    }

    private string BuildRequestJson()
    {
        using var ms = new System.IO.MemoryStream();
        using var w  = new Utf8JsonWriter(ms);
        w.WriteStartObject();
        foreach (var field in Stream.RequestFields)
        {
            if (!_fieldValues.TryGetValue(field.Name, out var raw) || string.IsNullOrEmpty(raw))
            {
                if (field.Optional) continue;
                throw new InvalidOperationException($"Required field '{field.Name}' is empty.");
            }
            WriteFieldToJson(w, field, raw);
        }
        w.WriteEndObject();
        w.Flush();
        return Encoding.UTF8.GetString(ms.ToArray());
    }

    private static void WriteFieldToJson(Utf8JsonWriter w, FieldDescriptor field, string raw)
    {
        w.WritePropertyName(field.WireKey);

        if (field.Enum is { WireType: "int" })
        {
            if (int.TryParse(raw, out var iv)) w.WriteNumberValue(iv);
            else w.WriteStringValue(raw);
            return;
        }
        if (field.Enum is { WireType: "string" })
        {
            w.WriteStringValue(raw);
            return;
        }

        switch (field.Type)
        {
            case "bool":
                w.WriteNumberValue(raw is "true" or "1" ? 1 : 0);
                break;
            case "int":
                if (long.TryParse(raw, out var lv)) w.WriteNumberValue(lv);
                else w.WriteStringValue(raw);
                break;
            case "uint":
                if (ulong.TryParse(raw, out var ulv)) w.WriteNumberValue(ulv);
                else w.WriteStringValue(raw);
                break;
            case "byte":
                if (byte.TryParse(raw, out var bv)) w.WriteNumberValue(bv);
                else w.WriteStringValue(raw);
                break;
            case "ushort":
                if (ushort.TryParse(raw, out var sv)) w.WriteNumberValue(sv);
                else w.WriteStringValue(raw);
                break;
            case "bytes":
            case "hex":
                w.WriteStringValue(raw);
                break;
            case "uint[]":
                w.WriteStartArray();
                foreach (var part in raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    if (ulong.TryParse(part, out var upart)) w.WriteNumberValue(upart);
                w.WriteEndArray();
                break;
            case "string[]":
                w.WriteStartArray();
                foreach (var part in raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    w.WriteStringValue(part);
                w.WriteEndArray();
                break;
            default:
                w.WriteStringValue(raw);
                break;
        }
    }

    private static string RenderEventField(FieldDescriptor field, Dictionary<string, JsonElement> fields)
    {
        if (!fields.TryGetValue(field.WireKey, out var el))
            return "(absent)";

        if (field.Enum is not null)
        {
            var wireVal = el.ValueKind == JsonValueKind.Number
                ? el.GetInt32().ToString()
                : el.GetString() ?? el.GetRawText();
            var match = field.Enum.Values.FirstOrDefault(v => v.WireValue == wireVal);
            return match is not null ? $"{match.Name} ({wireVal})" : wireVal;
        }

        return field.Type switch
        {
            "bool"     => el.ValueKind == JsonValueKind.Number
                              ? (el.GetInt32() != 0 ? "true" : "false")
                              : el.GetRawText(),
            "bytes"    => $"({el.GetString()?.Length ?? 0} chars b64)",
            "uint[]"   => el.ValueKind == JsonValueKind.Array
                              ? string.Join(", ", el.EnumerateArray().Select(e => e.GetRawText()))
                              : el.GetRawText(),
            "string[]" => el.ValueKind == JsonValueKind.Array
                              ? string.Join(", ", el.EnumerateArray().Select(e => e.GetString() ?? e.GetRawText()))
                              : el.GetRawText(),
            _ => el.GetRawText().Trim('"')
        };
    }

    public async ValueTask DisposeAsync()
    {
        _stopCts?.Cancel();
        if (_activeStream is not null)
        {
            await _activeStream.DisposeAsync().ConfigureAwait(false);
            _activeStream = null;
        }
        _stopCts?.Dispose();
        _stopCts = null;
    }
}
