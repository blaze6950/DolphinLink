@page "/"

@using FlipperZero.NET
@using FlipperZero.NET.Commands.System
@using FlipperZero.NET.Extensions
@using FlipperZero.Web.Services

@inject FlipperClientService Flipper

@implements IDisposable

<PageTitle>FlipperZero.NET Web Demo</PageTitle>

<h1>FlipperZero.NET — Browser Demo</h1>

@if (!Flipper.IsConnected)
{
    <p class="text-muted">
        Use the <strong>Connect to Flipper</strong> button in the top-right corner to connect.
    </p>
}
else
{
    @if (Flipper.DaemonInfo is not null)
    {
        <h5>Daemon</h5>
        <table class="table table-sm table-bordered w-auto mb-3">
            <tr><th>Name</th><td>@Flipper.DaemonInfo.Value.Name</td></tr>
            <tr><th>Protocol version</th><td>@Flipper.DaemonInfo.Value.Version</td></tr>
            <tr><th>Commands</th><td>@string.Join(", ", Flipper.DaemonInfo.Value.Commands ?? [])</td></tr>
        </table>
    }

    @if (Flipper.DeviceInfo is not null)
    {
        <h5>Device</h5>
        <table class="table table-sm table-bordered w-auto mb-4">
            <tr><th>Name</th><td>@Flipper.DeviceInfo.Value.Name</td></tr>
            <tr><th>Model</th><td>@Flipper.DeviceInfo.Value.Model</td></tr>
            <tr><th>Firmware</th><td>@Flipper.DeviceInfo.Value.Firmware (@Flipper.DeviceInfo.Value.GitBranch, @Flipper.DeviceInfo.Value.GitHash)</td></tr>
            <tr><th>Hardware rev</th><td>@Flipper.DeviceInfo.Value.Hardware</td></tr>
            <tr><th>UID</th><td><code>@Flipper.DeviceInfo.Value.Uid</code></td></tr>
            <tr><th>BLE MAC</th><td><code>@Flipper.DeviceInfo.Value.BleMac</code></td></tr>
        </table>
    }

    <h5>Commands</h5>
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-primary" @onclick="GetTimeAsync" disabled="@_busy">Get RTC time</button>
        <button class="btn btn-success"         @onclick="BlinkGreenAsync" disabled="@_busy">Blink green</button>
        <button class="btn btn-danger"          @onclick="BlinkRedAsync"   disabled="@_busy">Blink red</button>
    </div>

    @if (_commandResult is not null)
    {
        <div class="alert alert-info mt-3">@_commandResult</div>
    }
    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger mt-3">@_errorMessage</div>
    }
}

@code {
    private bool _busy;
    private string? _commandResult;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        Flipper.StateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Flipper.StateChanged -= OnStateChanged;
    }

    // ── Demo commands ─────────────────────────────────────────────────────────

    private async Task GetTimeAsync()
    {
        if (Flipper.Client is null) return;

        _busy = true;
        _commandResult = null;
        _errorMessage  = null;
        try
        {
            var response = await Flipper.Client.DatetimeGetAsync();
            _commandResult = $"Flipper RTC: {response.DateTime:yyyy-MM-dd HH:mm:ss}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Command failed: {ex.Message}";
        }
        finally { _busy = false; }
    }

    private async Task BlinkGreenAsync() => await BlinkAsync(0, 255, 0);
    private async Task BlinkRedAsync()   => await BlinkAsync(255, 0, 0);

    private async Task BlinkAsync(byte r, byte g, byte b)
    {
        if (Flipper.Client is null) return;

        _busy = true;
        _commandResult = null;
        _errorMessage  = null;
        try
        {
            await Flipper.Client.LedSetRgbAsync(new RgbColor(r, g, b));
            await Task.Delay(400);
            await Flipper.Client.LedSetRgbAsync(new RgbColor(0, 0, 0));
            _commandResult = "LED blinked.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Command failed: {ex.Message}";
        }
        finally { _busy = false; }
    }
}
