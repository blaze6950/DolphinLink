@page "/docs/{Slug}"

@inject MarkdownService Docs

<PageTitle>@(_title ?? "Documentation") — FlipperZero.NET</PageTitle>

@if (_markup is not null)
{
    <div class="markdown-body">
        @_markup
    </div>
}
else
{
    <h1>Not Found</h1>
    <p class="text-muted">No documentation page matches <code>@Slug</code>.</p>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private MarkupString? _markup;
    private string? _title;

    private static readonly Dictionary<string, string> SlugToKey = new(StringComparer.OrdinalIgnoreCase)
    {
        ["architecture"] = "ARCHITECTURE",
        ["protocol"]     = "PROTOCOL",
        ["schema"]       = "SCHEMA",
        ["diagnostics"]  = "DIAGNOSTICS",
    };

    protected override void OnParametersSet()
    {
        if (SlugToKey.TryGetValue(Slug, out var key))
        {
            _markup = Docs.GetMarkup(key);
            _title  = Docs.GetTitle(key);
        }
        else
        {
            _markup = null;
            _title  = null;
        }
    }
}
