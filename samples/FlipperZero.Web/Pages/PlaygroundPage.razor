@page "/playground"

@using FlipperZero.Web.Playground
@using FlipperZero.Web.Services
@using FlipperZero.Web.Components.Playground

@inject FlipperClientService Flipper
@inject IJSRuntime JS

@implements IDisposable

<PageTitle>Playground — FlipperZero.NET</PageTitle>

@* ── Global search bar ──────────────────────────────────────────────────────── *@
<div class="playground-search-bar mb-3">
    <div class="input-group">
        <span class="input-group-text bg-white border-end-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                 class="text-muted" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11"/>
            </svg>
        </span>
        <input class="form-control border-start-0 ps-0"
               type="search"
               placeholder="Search commands and streams across all subsystems…"
               @bind="_searchText"
               @bind:event="oninput"
               @bind:after="OnSearchChanged" />
        @if (!string.IsNullOrEmpty(_searchText))
        {
            <button class="btn btn-outline-secondary border-start-0"
                    type="button"
                    @onclick="ClearSearch">✕</button>
        }
    </div>
</div>

@* ── Main layout: sticky ToC + scrollable content ───────────────────────────── *@
<div class="playground-layout">

    @* ── Left: sticky ToC ─────────────────────────────────────────────────── *@
    @if (!_searching)
    {
        <nav class="playground-toc" aria-label="Subsystem navigation">
            <div class="playground-toc-title text-uppercase text-muted small fw-semibold mb-2 px-2">
                Subsystems
            </div>
            @foreach (var sub in SchemaRegistry.Subsystems)
            {
                var cmdCount    = sub.Commands.Count;
                var streamCount = sub.Streams.Count;
                var subName     = sub.Name;
                <button class="playground-toc-item @(_activeSubsystem == subName ? "active" : "")"
                        type="button"
                        @onclick="() => ScrollToSubsystem(subName)">
                    <span class="playground-toc-name">@subName</span>
                    <span class="playground-toc-badges">
                        @if (cmdCount > 0)
                        {
                            <span class="badge bg-secondary" title="@cmdCount command(s)">@cmdCount</span>
                        }
                        @if (streamCount > 0)
                        {
                            <span class="badge bg-info text-dark" title="@streamCount stream(s)">@streamCount</span>
                        }
                    </span>
                </button>
            }
        </nav>
    }

    @* ── Right: content ───────────────────────────────────────────────────── *@
    <div class="playground-content">

        @if (_searching)
        {
            @* Search results — flat list grouped by subsystem *@
            var matchedSubsystems = GetSearchResults();
            @if (matchedSubsystems.Count == 0)
            {
                <div class="text-muted fst-italic py-4 text-center">
                    No commands or streams match "<strong>@_searchText</strong>".
                </div>
            }
            else
            {
                <div class="mb-2 text-muted small">
                    @(matchedSubsystems.Sum(m => m.Commands.Count + m.Streams.Count)) result(s) across @matchedSubsystems.Count subsystem(s)
                </div>
                @foreach (var result in matchedSubsystems)
                {
                    <div class="playground-section">
                        <div class="playground-section-header">
                            <h4 class="playground-section-title">@result.SubsystemName</h4>
                        </div>
                        @foreach (var cmd in result.Commands)
                        {
                            <CommandPanel Command="cmd" />
                        }
                        @foreach (var stream in result.Streams)
                        {
                            <StreamPanel Stream="stream" />
                        }
                    </div>
                }
            }
        }
        else
        {
            @* Normal view — all subsystems ────────────────────────────────── *@
            @foreach (var sub in SchemaRegistry.Subsystems)
            {
                <div class="playground-section" id="sub-@sub.Name.ToLowerInvariant()">

                    @* Subsystem section header *@
                    <div class="playground-section-header">
                        <h4 class="playground-section-title">@sub.Name</h4>
                        <div class="playground-section-badges">
                            @if (sub.Commands.Count > 0)
                            {
                                <span class="badge bg-secondary">
                                    @sub.Commands.Count command@(sub.Commands.Count == 1 ? "" : "s")
                                </span>
                            }
                            @if (sub.Streams.Count > 0)
                            {
                                <span class="badge bg-info text-dark">
                                    @sub.Streams.Count stream@(sub.Streams.Count == 1 ? "" : "s")
                                </span>
                            }
                        </div>
                    </div>

                    @* Commands *@
                    @foreach (var cmd in sub.Commands)
                    {
                        <CommandPanel Command="cmd" />
                    }

                    @* Streams *@
                    @foreach (var stream in sub.Streams)
                    {
                        <StreamPanel Stream="stream" />
                    }

                </div>
            }
        }
    </div>
</div>

@code {
    private string _searchText   = "";
    private bool   _searching    => !string.IsNullOrWhiteSpace(_searchText);
    private string _activeSubsystem = SchemaRegistry.Subsystems.FirstOrDefault()?.Name ?? "";

    private sealed record SearchResult(
        string SubsystemName,
        IReadOnlyList<CommandDescriptor> Commands,
        IReadOnlyList<StreamDescriptor>  Streams);

    protected override void OnInitialized()
    {
        Flipper.StateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnSearchChanged() { /* reactive via @bind */ }

    private async Task ScrollToSubsystem(string name)
    {
        _activeSubsystem = name;
        await JS.InvokeVoidAsync("scrollToId", $"sub-{name.ToLowerInvariant()}");
    }

    private void ClearSearch()
    {
        _searchText = "";
    }

    private List<SearchResult> GetSearchResults()
    {
        var q       = _searchText.Trim();
        var results = new List<SearchResult>();

        foreach (var sub in SchemaRegistry.Subsystems)
        {
            var matchedCmds = sub.Commands
                .Where(c => Matches(c.Name, q)
                         || Matches(c.DisplayName, q)
                         || Matches(c.Description, q)
                         || c.RequestFields.Any(f => Matches(f.Name, q) || Matches(f.Description, q))
                         || c.ResponseFields.Any(f => Matches(f.Name, q) || Matches(f.Description, q)))
                .ToList();

            var matchedStreams = sub.Streams
                .Where(s => Matches(s.Name, q)
                         || Matches(s.DisplayName, q)
                         || Matches(s.Description, q)
                         || s.RequestFields.Any(f => Matches(f.Name, q) || Matches(f.Description, q))
                         || s.EventFields.Any(f => Matches(f.Name, q) || Matches(f.Description, q)))
                .ToList();

            if (matchedCmds.Count > 0 || matchedStreams.Count > 0)
                results.Add(new SearchResult(sub.Name, matchedCmds, matchedStreams));
        }

        return results;
    }

    private static bool Matches(string? text, string query) =>
        text is not null && text.Contains(query, StringComparison.OrdinalIgnoreCase);

    public void Dispose()
    {
        Flipper.StateChanged -= OnStateChanged;
    }
}
