@using FlipperZero.Web.Services

@inject FlipperClientService Flipper

@implements IDisposable

@* ConnectionBar — rendered in MainLayout's top-row on every page.
   Owns the connect/disconnect UX; delegates all logic to FlipperClientService. *@

@if (!Flipper.WebSerialSupported)
{
    <span class="badge bg-warning text-dark">WebSerial not supported</span>
}
else if (Flipper.IsConnected)
{
    <span class="badge bg-success me-2">Connected</span>
    <button class="btn btn-outline-secondary btn-sm"
            @onclick="DisconnectAsync"
            disabled="@Flipper.IsBusy">
        Disconnect
    </button>
}
else if (Flipper.IsBusy)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border spinner-border-sm text-secondary" role="status" aria-hidden="true"></div>
        <span class="small text-muted">@(Flipper.StatusMessage ?? "Working...")</span>

        @if (Flipper.ShowPickDaemonButton)
        {
            <button class="btn btn-primary btn-sm" @onclick="PickDaemonPortAsync">
                Select Daemon Port (CDC&nbsp;1)
            </button>
        }
    </div>
}
else
{
    <button class="btn btn-primary btn-sm" @onclick="ConnectAsync">
        Connect to Flipper
    </button>

    @* Daemon Metrics checkbox — only visible when disconnected and idle *@
    <div class="form-check form-switch mb-0 d-flex align-items-center gap-1 ms-2">
        <input class="form-check-input"
               type="checkbox"
               role="switch"
               id="daemon-metrics-toggle"
               checked="@Flipper.DaemonMetricsEnabled"
               @onchange="OnDaemonMetricsChanged" />
        <label class="form-check-label small text-muted" for="daemon-metrics-toggle">
            Daemon Metrics
        </label>
    </div>

    @if (Flipper.ErrorMessage is not null)
    {
        <span class="text-danger small ms-2" title="@Flipper.ErrorMessage">
            Connection failed
        </span>
    }
}

@code {
    protected override void OnInitialized()
    {
        Flipper.StateChanged += OnStateChanged;
    }

    private async Task ConnectAsync() => await Flipper.ConnectAsync();

    private async Task PickDaemonPortAsync() => await Flipper.PickDaemonPortAsync();

    private async Task DisconnectAsync() => await Flipper.DisconnectAsync();

    private void OnDaemonMetricsChanged(ChangeEventArgs e)
    {
        Flipper.DaemonMetricsEnabled = e.Value is true;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Flipper.StateChanged -= OnStateChanged;
    }
}
