@using System.Text
@using System.Text.Json
@using DolphinLink.Client.Exceptions

@inject ClientService Flipper

@* CommandPanel — renders a full request form and response area for a CommandDescriptor. *@

<div class="playground-item @(_collapsed ? "" : "playground-item--open") mb-2">

    @* ── Header (always visible) ────────────────────────────────────────────── *@
    <div class="playground-item-header"
         @onclick="ToggleCollapsed"
         title="@(_collapsed ? "Expand" : "Collapse")"
         role="button"
         tabindex="0"
         @onkeydown="OnKeyDown">

        @* Left cluster: method badge + name + id badge *@
        <div class="playground-item-left">
            <span class="playground-method-badge playground-method-badge--cmd">CMD</span>
            <span class="playground-item-name">@Command.DisplayName</span>
            <span class="badge bg-secondary font-monospace">#@Command.CommandId</span>
            @if (Command.Resource is not null)
            {
                <span class="badge playground-resource-badge" title="Acquires resource">@Command.Resource</span>
            }
        </div>

        @* Right cluster: description + expand arrow *@
        <div class="playground-item-right">
            <span class="playground-item-desc text-muted small">@Command.Description</span>
            <span class="playground-item-arrow" aria-hidden="true">@(_collapsed ? "▶" : "▼")</span>
        </div>
    </div>

    @* ── Body (expanded only) ───────────────────────────────────────────────── *@
    @if (!_collapsed)
    {
        <div class="playground-item-body">

            @* ── Metadata row ─────────────────────────────────────────────── *@
            <div class="playground-meta mb-3">
                <span class="font-monospace small text-muted me-3">
                    <span class="text-secondary">name:</span> @Command.Name
                </span>
                @if (Command.Errors.Count > 0)
                {
                    <span class="small text-muted">
                        <span class="text-secondary me-1">possible errors:</span>
                        @foreach (var err in Command.Errors)
                        {
                            <code class="me-1 playground-error-code">@err</code>
                        }
                    </span>
                }
            </div>

            @* ── Request section ──────────────────────────────────────────── *@
            @if (Command.RequestFields.Count > 0)
            {
                <div class="playground-section-label">Request parameters</div>
                <div class="playground-fields mb-3">
                    @foreach (var field in Command.RequestFields)
                    {
                        <FieldInput Field="field" Values="_fieldValues" ValuesChanged="OnValuesChanged" />
                    }
                </div>
            }

            @* ── Send button row ──────────────────────────────────────────── *@
            <div class="d-flex align-items-center gap-2 mb-3">
                <button class="btn btn-primary btn-sm px-3"
                        @onclick="SendAsync"
                        disabled="@(_busy || !Flipper.IsConnected)">
                    @if (_busy)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Send
                </button>
                @if (!Flipper.IsConnected)
                {
                    <span class="text-muted small">Not connected</span>
                }
                @if (_lastDurationMs.HasValue)
                {
                    <span class="badge bg-light text-dark border">@_lastDurationMs ms</span>
                }
                @if (_lastDurationMs.HasValue && _errorMessage is null)
                {
                    <span class="badge bg-success">OK</span>
                }
            </div>

            @* ── Error alert ──────────────────────────────────────────────── *@
            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <strong>Error:</strong> @_errorMessage
                </div>
            }

            @* ── Response section ─────────────────────────────────────────── *@
            @if (_responsePayload is not null || _responseJson is not null)
            {
                <div class="playground-section-label">Response</div>
                @if (Command.ResponseFields.Count == 0)
                {
                    <span class="badge bg-success mb-2">OK (void response)</span>
                }
                else
                {
                    <ResponseDisplay Fields="Command.ResponseFields" JsonResponse="_responsePayload" />
                }

                <details class="mt-2">
                    <summary class="text-muted small" style="cursor:pointer">Raw JSON</summary>
                    <pre class="border rounded p-2 mt-1 small bg-light font-monospace"
                         style="white-space:pre-wrap;word-break:break-all">@_responseJson</pre>
                </details>
            }

        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CommandDescriptor Command { get; set; } = null!;

    private Dictionary<string, string> _fieldValues = new();
    private bool   _busy;
    private bool   _collapsed   = true;
    private string? _errorMessage;
    private JsonElement? _responsePayload;
    private string? _responseJson;
    private long?  _lastDurationMs;

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ") ToggleCollapsed();
    }

    private Task OnValuesChanged(Dictionary<string, string> values)
    {
        _fieldValues = values;
        return Task.CompletedTask;
    }

    private async Task SendAsync()
    {
        if (Flipper.Client is null) return;

        _busy            = true;
        _errorMessage    = null;
        _responsePayload = null;
        _responseJson    = null;
        _lastDurationMs  = null;

        try
        {
            var argsJson = BuildRequestJson();

            using var argsDoc = JsonDocument.Parse(argsJson);
            var argsElement   = argsDoc.RootElement.Clone();

            var cmd = new GenericRpcCommand(Command.CommandId, Command.Name, argsElement);

            var sw   = System.Diagnostics.Stopwatch.StartNew();
            var resp = await Flipper.Client.SendAsync<GenericRpcCommand, GenericRpcResponse>(cmd)
                           .ConfigureAwait(false);
            sw.Stop();

            _lastDurationMs  = sw.ElapsedMilliseconds;
            _responsePayload = resp.ToJsonElement();
            _responseJson    = resp.ToRawJson();
        }
        catch (RpcException ex)
        {
            _errorMessage = $"{ex.ErrorCode}: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private string BuildRequestJson()
    {
        using var ms = new System.IO.MemoryStream();
        using var w  = new Utf8JsonWriter(ms);
        w.WriteStartObject();
        foreach (var field in Command.RequestFields)
        {
            if (!_fieldValues.TryGetValue(field.Name, out var raw) || string.IsNullOrEmpty(raw))
            {
                if (field.Optional) continue;
                throw new InvalidOperationException($"Required field '{field.Name}' is empty.");
            }
            WriteFieldToJson(w, field, raw);
        }
        w.WriteEndObject();
        w.Flush();
        return Encoding.UTF8.GetString(ms.ToArray());
    }

    private static void WriteFieldToJson(Utf8JsonWriter w, FieldDescriptor field, string raw)
    {
        w.WritePropertyName(field.WireKey);

        if (field.Enum is { WireType: "int" })
        {
            if (int.TryParse(raw, out var iv)) w.WriteNumberValue(iv);
            else w.WriteStringValue(raw);
            return;
        }

        if (field.Enum is { WireType: "string" })
        {
            w.WriteStringValue(raw);
            return;
        }

        switch (field.Type)
        {
            case "bool":
                w.WriteNumberValue(raw is "true" or "1" ? 1 : 0);
                break;
            case "int":
                if (long.TryParse(raw, out var lv)) w.WriteNumberValue(lv);
                else w.WriteStringValue(raw);
                break;
            case "uint":
                if (ulong.TryParse(raw, out var ulv)) w.WriteNumberValue(ulv);
                else w.WriteStringValue(raw);
                break;
            case "byte":
                if (byte.TryParse(raw, out var bv)) w.WriteNumberValue(bv);
                else w.WriteStringValue(raw);
                break;
            case "ushort":
                if (ushort.TryParse(raw, out var sv)) w.WriteNumberValue(sv);
                else w.WriteStringValue(raw);
                break;
            case "bytes":
            case "hex":
                w.WriteStringValue(raw);
                break;
            case "uint[]":
                w.WriteStartArray();
                foreach (var part in raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    if (ulong.TryParse(part, out var upart)) w.WriteNumberValue(upart);
                w.WriteEndArray();
                break;
            case "string[]":
                w.WriteStartArray();
                foreach (var part in raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    w.WriteStringValue(part);
                w.WriteEndArray();
                break;
            default:
                w.WriteStringValue(raw);
                break;
        }
    }
}
