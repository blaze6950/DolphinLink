# Default: normalize all text files to LF on commit, check out as-is on all platforms.
* text=auto eol=lf

# Force LF for source files (never CRLF in the repo).
*.cs        text eol=lf
*.csx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.razor     text eol=lf
*.xml       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
*.h         text eol=lf
*.c         text eol=lf
*.ps1       text eol=lf
*.sh        text eol=lf

# Windows-specific scripts — keep CRLF so cmd.exe / batch tools are happy.
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary files — no line-ending conversion.
*.fap       binary
*.png       binary
*.jpg       binary
*.ico       binary
*.wasm      binary
*.dll       binary
*.pdb       binary
*.zip       binary
*.gz        binary
